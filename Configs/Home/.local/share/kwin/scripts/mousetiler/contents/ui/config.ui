     <widget class="QWidget" name="tab_autoTile">
      <attribute name="icon">
       <iconset theme="process-working"/>
      </attribute>
      <attribute name="title">
       <string>Auto Tiling</string>
      </attribute>
      <layout class="QVBoxLayout" name="verticalLayout_25">
       <item>
        <widget class="QGroupBox" name="groupBox_16">
         <property name="title">
          <string/>
         </property>
         <layout class="QVBoxLayout" name="verticalLayout_27">
          <item>
           <widget class="QLabel" name="label_74">
            <property name="text">
             <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:700;&quot;&gt;Auto Tiling&lt;/span&gt;: Configure the auto tilier behavior. &lt;span style=&quot; color:#ffaa00;&quot;&gt;TIP&lt;/span&gt; You can use the &lt;a href=&quot;https://rxweb.epizy.com/mousetiler/editor.html&quot;&gt;&lt;span style=&quot; text-decoration: underline; color:#5294e2;&quot;&gt;graphical web editor&lt;/span&gt;&lt;/a&gt; to edit layouts - but need to manually add prefixes (such as 0:, 1:, 2:, -1 or *: )&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
            </property>
            <property name="openExternalLinks">
             <bool>true</bool>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QLabel" name="label_91">
            <property name="text">
             <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; color:#ffaa00;&quot;&gt;WARNING&lt;/span&gt; Add &amp;quot;Auto tile for id&amp;quot; or enable &amp;quot;Auto tile newly opened windows&amp;quot; at own risk. It should be safe now since auto-tiling received a lot of fixes and all known bugs have been fixed. But it is preferrable to manually auto tile each app/window and save/restore the auto tile status with Remember Window Positions (v5.4.1 or newer) if you can. Please report problematic apps on Discord so I can add them to default blacklist.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
            </property>
            <property name="wordWrap">
             <bool>true</bool>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QCheckBox" name="kcfg_autoTileNewWindows">
            <property name="text">
             <string>Auto tile newly opened windows - will auto-tile all new valid windows. If you want to auto tile per desktop, use &quot;Auto tile for id&quot; below instead. You can still auto tile using your mouse or keyboard shortcut (Ctrl+Alt+A)</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QCheckBox" name="kcfg_autoTilerEdgeScroll">
            <property name="text">
             <string>Scroll auto tiled windows by moving mouse to left / right screen edge. Carousel auto tilers have infinite scroll while normal auto tilers scroll if there are more windows than current layout can fit.</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QCheckBox" name="kcfg_autoTileMinimizedMaximized">
            <property name="text">
             <string>Auto tile windows that have been manually minimized, maximized or set to fullscreen once they return to default state</string>
            </property>
            <property name="checked">
             <bool>true</bool>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QCheckBox" name="kcfg_autoTileRestoreSize">
            <property name="text">
             <string>Restore size (and position if possible) when a window stops being auto tiled</string>
            </property>
            <property name="checked">
             <bool>true</bool>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QCheckBox" name="kcfg_autoTileRestoreSizeAndPosition">
            <property name="text">
             <string>Restore size and position when Mouse Tiler shuts down. Applies when Mouse Tiler closes before the window (such as when reloading while changing settings). Use to make sure windows stay on screen.</string>
            </property>
           </widget>
          </item>
          <item>
           <layout class="QFormLayout" name="formLayout_9">
            <item row="1" column="1">
             <widget class="QLineEdit" name="kcfg_autoTileBlacklist"/>
